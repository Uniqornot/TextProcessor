<Window x:Class="TextProcessor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TextProcessor.ViewModels"
        Title="{StaticResource AppTitle}"
        MinWidth="900"
        MinHeight="600"
        Width="1100"
        Height="750"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundGrayBrush}"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TopBar -->
        <Border Grid.Row="0" Padding="24,20,24,16" Background="{StaticResource BackgroundGrayBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBlock Text="{StaticResource AppTitle}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="🌐"
                                   FontSize="14"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{StaticResource LanguageLabel}"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="{StaticResource AppSubtitle}"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.45*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="0.55*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,0,8,0">
                <StackPanel>

                    <!-- Исходный текст -->
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="{StaticResource SourceTextTitle}"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="{StaticResource PasteButton}"
                                            Style="{StaticResource AccentTextButtonStyle}"
                                            Command="{Binding PasteInputCommand}"/>
                                    <Button Content="{StaticResource ClearButton}"
                                            Style="{StaticResource SecondaryTextButtonStyle}"
                                            Command="{Binding ClearInputCommand}"/>
                                </StackPanel>
                            </Grid>

                            <TextBox Grid.Row="1"
                                     Style="{StaticResource PlaceholderTextBoxStyle}"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"/>

                            <WrapPanel Grid.Row="2" Margin="0,12,0,0">
                                <TextBlock Text="{StaticResource StatCharacters}" Style="{StaticResource StatLabelStyle}"/>
                                <TextBlock Text="{Binding CharCount}" Style="{StaticResource StatValueStyle}"/>
                                <TextBlock Text="{StaticResource StatWords}" Style="{StaticResource StatLabelStyle}"/>
                                <TextBlock Text="{Binding WordCount}" Style="{StaticResource StatValueStyle}"/>
                                <TextBlock Text="{StaticResource StatLines}" Style="{StaticResource StatLabelStyle}"/>
                                <TextBlock Text="{Binding LineCount}" Style="{StaticResource StatValueStyle}"/>
                                <TextBlock Text="{StaticResource StatParagraphs}" Style="{StaticResource StatLabelStyle}"/>
                                <TextBlock Text="{Binding ParagraphCount}" Style="{StaticResource StatValueStyle}"/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <!-- Инструменты обработки -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="{StaticResource ToolsTitle}"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,12"/>

                            <Button Content="{StaticResource FullCleanButton}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding FullCleanCommand}"
                                    Margin="0,0,0,8"/>

                            <Button Command="{Binding RemoveExtraSpacesCommand}" Style="{StaticResource SecondaryButtonStyle}">
                                <TextBlock Text="{StaticResource RemoveSpacesButton}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                            <Button Command="{Binding ToSingleLineCommand}" Style="{StaticResource SecondaryButtonStyle}">
                                <TextBlock Text="{StaticResource SingleLineButton}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                            <Button Command="{Binding FixParagraphsCommand}" Style="{StaticResource SecondaryButtonStyle}">
                                <TextBlock Text="{StaticResource FixParagraphsButton}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                            <Button Command="{Binding SmartNormalizeCommand}" Style="{StaticResource SecondaryButtonStyle}">
                                <TextBlock Text="{StaticResource SmartNormalizeButton}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                            <Button Command="{Binding DeNormalizeDashesCommand}" Style="{StaticResource SecondaryButtonStyle}">
                                <TextBlock Text="{StaticResource DeNormalizeDashesButton}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                            <Button Command="{Binding DenormalizeQuotesCommand}" Style="{StaticResource SecondaryButtonStyle}">
                                <TextBlock Text="{StaticResource DenormalizeQuotesButton}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                            <Button Command="{Binding RemoveHiddenCharsCommand}" Style="{StaticResource SecondaryButtonStyle}">
                                <TextBlock Text="{StaticResource RemoveHiddenButton}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                            <Button Command="{Binding ManageLineBreaksCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0">
                                <TextBlock Text="{StaticResource ManageLineBreaksButton}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Разделитель -->
            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource BorderGrayBrush}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Правая колонка -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="8,0,0,0">
                <StackPanel>

                    <!-- Обработанный текст -->
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="{StaticResource ProcessedTextTitle}"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="{StaticResource CopyButton}"
                                            Style="{StaticResource AccentTextButtonStyle}"
                                            Command="{Binding CopyOutputCommand}"
                                            IsEnabled="{Binding HasOutput}"/>
                                    <Button Content="{StaticResource ClearButton}"
                                            Style="{StaticResource SecondaryTextButtonStyle}"
                                            Command="{Binding ClearOutputCommand}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" MinHeight="200">
                                <TextBox Style="{StaticResource OutputTextBoxStyle}"
                                         Text="{Binding OutputText, UpdateSourceTrigger=PropertyChanged}"/>

                                <!-- Пустое состояние -->
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            IsHitTestVisible="False">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasOutput}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="📄"
                                               FontSize="40"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{StaticResource OutputEmptyText}"
                                               FontSize="14"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <WrapPanel Grid.Row="2" Margin="0,12,0,0">
                                <TextBlock Text="{StaticResource StatCharacters}" Style="{StaticResource StatLabelStyle}"/>
                                <TextBlock Text="{Binding OutputCharCount}" Style="{StaticResource StatValueStyle}"/>
                                <TextBlock Text="{StaticResource StatWords}" Style="{StaticResource StatLabelStyle}"/>
                                <TextBlock Text="{Binding OutputWordCount}" Style="{StaticResource StatValueStyle}"/>
                                <TextBlock Text="{StaticResource StatLines}" Style="{StaticResource StatLabelStyle}"/>
                                <TextBlock Text="{Binding OutputLineCount}" Style="{StaticResource StatValueStyle}"/>
                                <TextBlock Text="{StaticResource StatParagraphs}" Style="{StaticResource StatLabelStyle}"/>
                                <TextBlock Text="{Binding OutputParagraphCount}" Style="{StaticResource StatValueStyle}"/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <!-- Возможности обработки -->
                    <Border Style="{StaticResource CardStyle}" Margin="0">
                        <StackPanel>
                            <ToggleButton Style="{StaticResource ExpandToggleStyle}"
                                          IsChecked="{Binding IsFeaturesExpanded, Mode=TwoWay}"
                                          HorizontalContentAlignment="Stretch">
                                <Grid>
                                    <TextBlock Text="{StaticResource FeaturesTitle}"
                                               Style="{StaticResource SectionTitleStyle}"
                                               HorizontalAlignment="Left"/>
                                    <TextBlock HorizontalAlignment="Right"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="▼"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFeaturesExpanded}" Value="True">
                                                        <Setter Property="Text" Value="▲"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </ToggleButton>

                            <Border x:Name="FeaturesContent"
                                    ClipToBounds="True"
                                    MaxHeight="0"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <!-- Удаление скрытых символов -->
                                    <Border Style="{StaticResource FeatureRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="30" Height="30" CornerRadius="8" Background="#EDEBFE" Margin="0,0,10,0">
                                                <TextBlock Text="🛡" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6741D9"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{StaticResource FeatureHiddenTitle}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{StaticResource FeatureHiddenDesc}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Умная нормализация -->
                                    <Border Style="{StaticResource FeatureRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="30" Height="30" CornerRadius="8" Background="#E3FAF0" Margin="0,0,10,0">
                                                <TextBlock Text="✨" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#0CA678"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{StaticResource FeatureNormalizeTitle}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{StaticResource FeatureNormalizeDesc}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Точный подсчёт слов -->
                                    <Border Style="{StaticResource FeatureRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="30" Height="30" CornerRadius="8" Background="#E7EBFF" Margin="0,0,10,0">
                                                <TextBlock Text="🎯" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#4263EB"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{StaticResource FeatureWordsTitle}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{StaticResource FeatureWordsDesc}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Контроль пробелов -->
                                    <Border Style="{StaticResource FeatureRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="30" Height="30" CornerRadius="8" Background="#F1E9FE" Margin="0,0,10,0">
                                                <TextBlock Text="⚗" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#9C36B5"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{StaticResource FeatureSpacesTitle}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{StaticResource FeatureSpacesDesc}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Управление переносами -->
                                    <Border Style="{StaticResource FeatureRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="30" Height="30" CornerRadius="8" Background="#FFF1E6" Margin="0,0,10,0">
                                                <TextBlock Text="↵" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E8590C"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{StaticResource FeatureBreaksTitle}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{StaticResource FeatureBreaksDesc}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Пакетная обработка -->
                                    <Border Style="{StaticResource FeatureRowStyle}" Margin="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="30" Height="30" CornerRadius="8" Background="#FFE9E9" Margin="0,0,10,0">
                                                <TextBlock Text="⚡" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E03131"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{StaticResource FeatureBatchTitle}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{StaticResource FeatureBatchDesc}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
